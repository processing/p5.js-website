---
import { getEntry, type CollectionEntry } from "astro:content";
import HomepageLayout from "../layouts/HomepageLayout.astro";
import { defaultLocale } from "../i18n/const";
import { setJumpToState } from "../globals/state";

setJumpToState(null);
const homePageConfig = await getEntry("homepage", defaultLocale) as CollectionEntry<"homepage">;
---

<HomepageLayout config={homePageConfig} />
